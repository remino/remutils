# vim: set ft=ruby :
class Webshot < Formula
  desc "Capture a webpage as an image."
  version "{{version}}"
  url "https://github.com/remino/remutils/releases/download/{{tag}}/{{tag}}.tar.gz"
  sha256 "{{sha256}}"
  license "ISC"
  homepage "https://github.com/remino/remutils"

  depends_on "node"

  livecheck do
    url :stable
    strategy :github_latest
  end

  def install
    libexec.install Dir["*"]
    cd libexec do
      system "npm", "install", "--omit=dev"
    end

    bin.install_symlink libexec / "{{name}}" => "{{name}}"
    man1.install libexec / "man/{{name}}.1"
  end

  test do
    out = shell_output("#{bin}/{{name}} -h")
    assert_match "Usage: {{name}}", out
  end
end
