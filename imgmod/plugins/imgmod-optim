#!/usr/bin/env bash
# imgmod optim
# Optimize image files directly.

VERSION='1.1.0'

SCRIPT_PATH="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)/$(basename -- "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
IMGMOD_LIB="${IMGMOD_LIB:-$(dirname "$SCRIPT_DIR")/lib/imgmod.sh}"

# shellcheck source=../lib/imgmod.sh
. "$IMGMOD_LIB"

optim_start() {
	local input=
	local output=
	local opt

	OPTIND=1
	while getopts h opt; do
		case $opt in
			h)
				optim_help
				return
				;;
			*) optim_invalid_opt ;;
		esac
	done

	shift "$((OPTIND - 1))"

	[ $# -lt 1 ] && optim_help && return $E_ARGS
	[ $# -gt 2 ] && optim_help && return $E_ARGS

	input="$1"
	output="${2:-$input}"

	[ ! -f "$input" ] && _fatal $E_NO_FILE "No such file: $input"

	if [ "$output" != "$input" ]; then
		cp "$input" "$output"
	fi

	_require image_optim
	image_optim "$output"
	imgmod_output "$output"
}

optim_help() {
	cat << USAGE
$USAGE_NAME $VERSION

USAGE: $USAGE_NAME [<options>] <input> [output]

Optimize an image file with image_optim.

When output is omitted, the input file is optimized in place. When output is
provided, the input is copied there first and the copy is optimized.

OPTIONS:

	-h        Show this help screen.
	-v        Show plugin name and version number.

USAGE
}

optim_invalid_opt() {
	_error "Invalid option: $opt"
	_echo
	optim_help
	exit $E_ARGS
}

imgmod_plugin_run "$@"
