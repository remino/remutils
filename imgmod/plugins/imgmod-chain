#!/usr/bin/env bash
# imgmod chain
# Run multiple imgmod plugins in sequence.

VERSION='2.0.0'

SCRIPT_PATH="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)/$(basename -- "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
IMGMOD_LIB="${IMGMOD_LIB:-$(dirname "$SCRIPT_DIR")/lib/imgmod.sh}"
IMGMOD_PLUGIN_DIR="${IMGMOD_PLUGIN_DIR:-$SCRIPT_DIR}"

# shellcheck source=../lib/imgmod.sh
. "$IMGMOD_LIB"

chain_start() {
	local opt

	OPTIND=1
	while getopts h opt; do
		case $opt in
			h)
				chain_help
				return
				;;
			*) chain_invalid_opt ;;
		esac
	done

	shift "$((OPTIND - 1))"

	chain_run "$@"
}

chain_help() {
	cat << USAGE
$USAGE_NAME $VERSION

USAGE: $USAGE_NAME <command> [<options>] -- <command> [<options>] -- <input> <output>

Run multiple imgmod plugins in sequence.

Each command must follow the imgmod plugin argument style:

	<command> [<options>] [-o output] <input>

OPTIONS:

	-h        Show this help screen.
	-v        Show plugin name and version number.

USAGE
}

chain_run() {
	local args=("$@")
	local last_sep=-1
	local i
	local input
	local output
	local output_ext
	local tmp_dir
	local current_input
	local stage_output
	local final_stage
	local status
	local stage_count=0
	local validate_start
	local validate_len
	local validate_stage_count=0

	for ((i = 0; i < ${#args[@]}; i++)); do
		if [ "${args[i]}" = -- ]; then
			last_sep=$i
		fi
	done

	if [ "$last_sep" -lt 1 ] || [ "$((${#args[@]} - last_sep - 1))" -ne 2 ]; then
		chain_help
		return $E_ARGS
	fi

	validate_start=0
	while [ "$validate_start" -lt "$last_sep" ]; do
		validate_len=0
		while [ "$((validate_start + validate_len))" -lt "$last_sep" ] && [ "${args[validate_start + validate_len]}" != -- ]; do
			validate_len=$((validate_len + 1))
		done

		[ "$validate_len" -eq 0 ] && chain_help && return $E_ARGS
		validate_stage_count=$((validate_stage_count + 1))
		validate_start=$((validate_start + validate_len + 1))
	done

	[ "$validate_stage_count" -lt 2 ] && chain_help && return $E_ARGS

	input="${args[last_sep + 1]}"
	output="${args[last_sep + 2]}"
	imgmod_prepare_output "$output"
	output_ext="$(chain_output_extension "$output")"
	tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/imgmod-chain.XXXXXX")"
	current_input="$input"

	trap 'status=$?; rm -rf "$tmp_dir"; exit "$status"' INT TERM EXIT

	local start=0
	local len
	while [ "$start" -lt "$last_sep" ]; do
		len=0
		while [ "$((start + len))" -lt "$last_sep" ] && [ "${args[start + len]}" != -- ]; do
			len=$((len + 1))
		done

		if [ "$len" -eq 0 ]; then
			chain_help
			return $E_ARGS
		fi

		stage_count=$((stage_count + 1))
		final_stage=0
		if [ "$((start + len))" -eq "$last_sep" ]; then
			final_stage=1
			stage_output="$output"
		else
			stage_output="$tmp_dir/stage-$stage_count.$output_ext"
		fi

		chain_run_stage "$current_input" "$stage_output" "$final_stage" "${args[@]:start:len}"
		status=$?
		if [ "$status" -ne 0 ]; then
			return "$status"
		fi

		current_input="$stage_output"
		start=$((start + len + 1))
	done

	rm -rf "$tmp_dir"
	trap _exit INT TERM
	trap - EXIT
}

chain_run_stage() {
	local input=$1
	local output=$2
	local final_stage=$3
	local command_name=$4
	local plugin

	shift 4

	chain_validate_command "$command_name"

	plugin="$(imgmod_find_plugin "$command_name")"
	[ -n "$plugin" ] || _fatal "$E_ARGS" "Invalid chain command: $command_name"

	if [ "$final_stage" -eq 1 ]; then
		IMGMOD_PLUGIN_NAME="$command_name" "$plugin" "$@" -o "$output" "$input"
	else
		IMGMOD_PLUGIN_NAME="$command_name" IMGMOD_OUTPUTS_FILE= "$plugin" "$@" -o "$output" "$input" > /dev/null
	fi
}

chain_validate_command() {
	local command_name=$1

	case "$command_name" in
		'' | chain | completion | help | newplugin | version)
			_fatal "$E_ARGS" "Command cannot be chained: $command_name"
			;;
	esac
}

chain_output_extension() {
	local output=$1
	local name
	local ext

	name="$(basename "$output")"
	if [[ "$name" == *.* ]]; then
		ext="${name##*.}"
	else
		ext=tmp
	fi

	_echo "$ext"
}

chain_invalid_opt() {
	_error "Invalid option: $opt"
	_echo
	chain_help
	exit $E_ARGS
}

imgmod_plugin_run "$@"
