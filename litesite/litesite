site_root="$PWD"

while [[ $# -gt 0 ]]; do
	case "$1" in
		-C | --cwd)
			[[ $# -ge 2 ]] || {
				echo "litesite: missing argument for $1" >&2
				exit 1
			}
			site_root="$2"
			shift 2
			;;
		-h | --help)
			usage
			exit 0
			;;
		-v | --version)
			echo "$SCRIPT_NAME $VERSION"
			exit 0
			;;
		-v | --version)
			echo "litesite $VERSION"
			exit 0
			;;
		--)
			shift
			break
			;;
		-*)
			echo "litesite: unknown option: $1" >&2
			exit 1
			;;
		*)
			break
			;;
	esac
done

command="${1:-help}"
if [[ $# -gt 0 ]]; then
	shift
fi

case "$command" in
	build)
		ensure_site_root "$site_root"
		build_site "$site_root/src" "$site_root/dist"
		;;
	clean)
		ensure_site_root "$site_root"
		rm -rf "$site_root/dist"
		;;
	serve)
		ensure_site_root "$site_root"
		serve_site "$site_root/src"
		;;
	help)
		usage
		;;
	deploy)
		ensure_site_root "$site_root"
		deploy_mode="wet"
		if [[ "${1:-}" == "-n" ]]; then
			deploy_mode="dry"
			shift
		fi

		build_site "$site_root/src" "$site_root/dist"
		if [[ "$deploy_mode" == wet ]]; then
			(cd "$site_root" && rsdeploy -s dist/ -f .deploy-filter -w "$@")
		else
			(cd "$site_root" && rsdeploy -s dist/ -f .deploy-filter "$@")
		fi
		;;
	compress)
		ensure_site_root "$site_root"
		build_brotli "$site_root/dist"
		build_gzip "$site_root/dist"
		;;
	media)
		ensure_site_root "$site_root"
		build_media "$site_root/dist"
		;;
	new | init)
		init_site "${1:-}" "${2:-}"
		;;
	jpg)
		if [[ $# -eq 0 ]]; then
			echo "USAGE: litesite jpg <file.avif> [<file.avif...>]" >&2
			exit 1
		fi

		for file in "$@"; do
			avif_to_jpg "$file"
		done
		;;
	webp | webm)
		if [[ $# -eq 0 ]]; then
			echo "USAGE: litesite webp <file.avif> [<file.avif...>]" >&2
			exit 1
		fi

		for file in "$@"; do
			avif_to_webp "$file"
		done
		;;
	version)
		echo "litesite $VERSION"
		;;
	help)
		usage
		;;
	*)
		echo "litesite: unknown command: $command" >&2
		usage >&2
		exit 1
		;;
esac
