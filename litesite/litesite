#!/usr/bin/env bash
set -euo pipefail

VERSION="1.1.0"
SCRIPT_NAME="$(basename "$0")"

usage() {
	cat << EOF
litesite $VERSION

USAGE: litesite [<options>] [<command> [<args...>]]

Create and work with tiny static sites that keep their source in src/ and
publish to dist/.

COMMANDS:

	build                 Build dist/ from src/
	clean                 Remove dist/
	serve                 Run a local preview server
	deploy                Build and deploy dist/; use -n for a dry-run
	compress              Regenerate Brotli and gzip files
	media                 Regenerate AVIF JPG and WebP derivatives
	new <slug> [<dest>]   Create a new site scaffold
	init <slug> [<dest>]  Alias for new
	jpg <files...>        Convert AVIF files to JPG
	webp <files...>       Convert AVIF files to WebP

OPTIONS:

	-C <dir>    Run the command against a different site root.
	-h          Show this help screen.
	-v          Show version information.

When no command is supplied, this screen is shown.
EOF
}

ensure_site_root() {
	local root="$1"
	local missing=0
	local required

	for required in src .deploy-filter justfile .editorconfig; do
		if [[ ! -e "$root/$required" ]]; then
			echo "litesite: expected $root/$required" >&2
			missing=1
		fi
	done

	((missing == 0)) || exit 1
}

load_site_env() {
	local root="$1"
	local old_minify="${LITESITE_BUILD_MINIFY-__unset__}"
	local old_brotli="${LITESITE_BUILD_BROTLI-__unset__}"
	local old_gzip="${LITESITE_BUILD_GZIP-__unset__}"
	local old_avif_jpeg="${LITESITE_BUILD_AVIF_JPEG-__unset__}"
	local old_avif_webp="${LITESITE_BUILD_AVIF_WEBP-__unset__}"

	if [[ -f "$root/.env" ]]; then
		set -a
		# shellcheck disable=SC1090
		. "$root/.env"
		set +a
		if [[ "$old_minify" != __unset__ ]]; then
			export LITESITE_BUILD_MINIFY="$old_minify"
		fi
		if [[ "$old_brotli" != __unset__ ]]; then
			export LITESITE_BUILD_BROTLI="$old_brotli"
		fi
		if [[ "$old_gzip" != __unset__ ]]; then
			export LITESITE_BUILD_GZIP="$old_gzip"
		fi
		if [[ "$old_avif_jpeg" != __unset__ ]]; then
			export LITESITE_BUILD_AVIF_JPEG="$old_avif_jpeg"
		fi
		if [[ "$old_avif_webp" != __unset__ ]]; then
			export LITESITE_BUILD_AVIF_WEBP="$old_avif_webp"
		fi
	fi
}

env_enabled() {
	local name="$1"
	local value="${!name:-1}"

	case "${value,,}" in
		0 | false | no | off | "")
			return 1
			;;
		*)
			return 0
			;;
	esac
}

minify_html() {
	local input="$1"
	local output="$2"
	local tmp

	mkdir -p "$(dirname "$output")"
	tmp="$(mktemp)"

	npx --yes html-minifier-terser \
		--collapse-boolean-attributes \
		--collapse-whitespace \
		--remove-attribute-quotes \
		--remove-comments \
		--remove-empty-attributes \
		--remove-redundant-attributes \
		--remove-script-type-attributes \
		--remove-style-link-type-attributes \
		--remove-optional-tags \
		--remove-tag-whitespace \
		--minify-css false \
		--minify-js true \
		"$input" > "$tmp"

	node - "$tmp" "$output" << 'NODE'
const fs = require('node:fs')
const { execFileSync } = require('node:child_process')

const [input, output] = process.argv.slice(2)
const html = fs.readFileSync(input, 'utf8')

const minifyCss = (css) =>
	execFileSync(
		'npx',
		['--yes', '-p', 'lightningcss-cli', 'lightningcss', '-m'],
		{ input: css, encoding: 'utf8' },
	).trim()

const transformed = html.replace(/<style([^>]*)>([\s\S]*?)<\/style>/gi, (match, attrs, css) => {
	return `<style${attrs}>${minifyCss(css)}</style>`
})

fs.writeFileSync(output, transformed)
NODE

	rm -f "$tmp"
}

minify_js() {
	local input="$1"
	local output="$2"

	mkdir -p "$(dirname "$output")"
	npx --yes terser "$input" \
		--compress \
		--mangle \
		--comments '/^!/' \
		--output "$output"
}

minify_css() {
	local input="$1"
	local output="$2"

	mkdir -p "$(dirname "$output")"
	npx --yes -p lightningcss-cli lightningcss -m "$input" -o "$output"
}

copy_file() {
	local input="$1"
	local output="$2"

	mkdir -p "$(dirname "$output")"
	cp -p "$input" "$output"
}

avif_to_jpg() {
	local input="$1"
	local output="${2:-$input.jpg}"

	[[ -f "$input" ]] || exit 0
	mkdir -p "$(dirname "$output")"
	magick "$input" -auto-orient -background white -alpha remove -strip -quality 85 "$output"
}

avif_to_webp() {
	local input="$1"
	local output="${2:-$input.webp}"

	[[ -f "$input" ]] || exit 0
	mkdir -p "$(dirname "$output")"
	magick "$input" -auto-orient -background white -alpha remove -strip -quality 82 "$output"
}

build_media() {
	local dist="$1"
	local mode="${2:-all}"
	local build_jpg=1
	local build_webp=1

	[[ -d "$dist" ]] || exit 0

	case "$mode" in
		all | both | "") ;;
		jpg)
			build_webp=0
			;;
		webp | webm)
			build_jpg=0
			;;
		*)
			echo "litesite: invalid media mode: $mode" >&2
			exit 1
			;;
	esac

	while IFS= read -r -d '' file; do
		if ((build_jpg)); then
			avif_to_jpg "$file"
		fi
		if ((build_webp)); then
			avif_to_webp "$file"
		fi
	done < <(find "$dist" -type f -name '*.avif' -print0)
}

build_brotli() {
	local target="$1"

	[[ -d "$target" ]] || exit 0

	find "$target" -type f \
		\( -name '*.html' -o -name '*.css' -o -name '*.js' -o -name '*.mjs' -o -name '*.cjs' -o -name '*.svg' -o -name '*.json' -o -name '*.xml' -o -name '*.txt' -o -name '*.webmanifest' -o -name '*.wasm' \) \
		! -name '*.br' ! -name '*.gz' \
		-print0 \
		| while IFS= read -r -d '' file; do
			brotli -q 11 -fk "$file"
		done
}

build_gzip() {
	local target="$1"

	[[ -d "$target" ]] || exit 0

	find "$target" -type f \
		\( -name '*.html' -o -name '*.css' -o -name '*.js' -o -name '*.mjs' -o -name '*.cjs' -o -name '*.svg' -o -name '*.json' -o -name '*.xml' -o -name '*.txt' -o -name '*.webmanifest' -o -name '*.wasm' \) \
		! -name '*.br' ! -name '*.gz' \
		-print0 \
		| while IFS= read -r -d '' file; do
			gzip -9fk "$file"
		done
}

build_site() {
	local src="$1"
	local dist="$2"
	local root

	root="$(dirname "$src")"
	load_site_env "$root"
	rm -rf "$dist"
	minify_site "$src" "$dist"
	if env_enabled LITESITE_BUILD_AVIF_JPEG; then
		build_media "$dist" jpg
	fi
	if env_enabled LITESITE_BUILD_AVIF_WEBP; then
		build_media "$dist" webp
	fi
	if env_enabled LITESITE_BUILD_BROTLI; then
		build_brotli "$dist"
	fi
	if env_enabled LITESITE_BUILD_GZIP; then
		build_gzip "$dist"
	fi
}

minify_site() {
	local src="$1"
	local dist="$2"
	local minify=1

	if ! env_enabled LITESITE_BUILD_MINIFY; then
		minify=0
	fi

	mkdir -p "$dist"

	while IFS= read -r -d '' file; do
		local rel target
		rel="${file#"$src"/}"
		target="$dist/$rel"

		if ((minify)); then
			case "$rel" in
				public/*.html)
					minify_html "$file" "$target"
					;;
				public/*.js | public/*.mjs | public/*.cjs)
					minify_js "$file" "$target"
					;;
				public/*.css)
					minify_css "$file" "$target"
					;;
				public/*)
					copy_file "$file" "$target"
					;;
				*.html)
					minify_html "$file" "$target"
					;;
				*.js | *.mjs | *.cjs)
					minify_js "$file" "$target"
					;;
				*.css)
					minify_css "$file" "$target"
					;;
				*)
					copy_file "$file" "$target"
					;;
			esac
		else
			copy_file "$file" "$target"
		fi
	done < <(find "$src" -type f -print0)
}

serve_site() {
	local src="$1"

	local site_root
	local path_prefix
	site_root="$(cd "$(dirname "$src")" && pwd)"
	path_prefix="$site_root/"

	npx --yes live-server "$src/public" --host=0.0.0.0 --port="${PORT:-8080}" --no-browser 2>&1 \
		| while IFS= read -r line; do
			printf '%s\n' "${line//$path_prefix/./}"
		done
}

init_site() {
	local slug="${1:-}"
	local dest="${2:-}"

	if [[ -z "$slug" ]]; then
		echo "USAGE: litesite new <site_slug> [<dest_dir>]" >&2
		exit 1
	fi

	if [[ "$slug" == *"/"* ]]; then
		echo "litesite: SITE_SLUG must not contain /" >&2
		exit 1
	fi

	dest="${dest:-./$slug}"

	if [[ -e "$dest" ]]; then
		echo "litesite: destination already exists: $dest" >&2
		exit 1
	fi

	mkdir -p "$dest/src/public/$slug" "$dest/src/nginx"

	cat > "$dest/.editorconfig" << 'EOF'
root = true

[*]
end_of_line = lf
insert_final_newline = true
indent_size = 2
indent_style = tab

# shfmt
binary_next_line = true
function_next_line = false
keep_padding = false
never_split = true
shell_variant = bash
space_redirects = true
switch_case_indent = true

[*.md]
trim_trailing_whitespace = false
indent_size = 4
indent_style = space

[*.{yaml,yml}]
indent_style = space
EOF

	cat > "$dest/.deploy-filter" << 'EOF'
- .DS_Store
EOF

	cat > "$dest/.gitignore" << 'EOF'
dist/
node_modules/
.DS_Store
.env
EOF

	cat > "$dest/.env.example" << 'EOF'
RSDEPLOY_DEST=host:example.com/path/
RSDEPLOY_SRC=dist
RSDEPLOY_FILTER=.deploy-filter
LITESITE_BUILD_BROTLI=1
LITESITE_BUILD_GZIP=1
LITESITE_BUILD_MINIFY=1
LITESITE_BUILD_AVIF_JPEG=1
LITESITE_BUILD_AVIF_WEBP=1
EOF

	cp "$dest/.env.example" "$dest/.env"

	cat > "$dest/justfile" << 'EOF'
set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

default: serve

build:
    litesite build

clean:
    litesite clean

serve:
    litesite serve

deploy:
    litesite deploy

compress:
    litesite compress

media:
    litesite media

new slug="":
    litesite new '{{slug}}'

init slug="":
    litesite init '{{slug}}'

jpg *files:
    litesite jpg {{files}}

webp *files:
    litesite webp {{files}}
EOF

	cat > "$dest/README.md" << 'EOF'
# __SITE_SLUG__

Boilerplate and command wrapper for tiny sites that do not need a framework.

## Layout

- Source lives in `src/`
- Publishable output goes in `dist/`
- Public files in `src/public/` are copied to `dist/public/`

## Development

```bash
