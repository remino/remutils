#!/usr/bin/env bash

_usage() {
	echo "USAGE: $(basename "$0") <script_dir> <initial|major|minor|patch> [--github]"
}

release_main() {
	# export PS4='+ ${BASH_SOURCE}:${LINENO}:${FUNCNAME[0]}() '
	# set -x
	set -euo pipefail

	E_ARGS=16
	E_MISSING_FILE=17
	E_MISSING_APP=19
	E_EXISTING_TAG=20

	[ $# -eq 0 ] && _usage && return
	[ $# -lt 2 ] && _usage && return $E_ARGS

	SELF_SCRIPT="$(realpath "${BASH_SOURCE[0]}")"
	SELF_DIR="$(dirname "$SELF_SCRIPT")"
	PATH="$SELF_DIR:$PATH"

	SCRIPT_DIR="$1"
	TYPE="$2"
	shift 2

	PUBLISH_GITHUB=0
	while [ $# -gt 0 ]; do
		case "$1" in
			--github) PUBLISH_GITHUB=1 ;;
			*) _fatal $E_ARGS "Invalid argument: $1" ;;
		esac
		shift
	done

	[ ! -d "$SCRIPT_DIR" ] && _fatal $E_MISSING_FILE "Missing or not a directory: $SCRIPT_DIR"

	SCRIPT_NAME="$(basename "$SCRIPT_DIR")"
	SCRIPT_FILE="$SCRIPT_DIR/$SCRIPT_NAME"

	[ ! -f "$SCRIPT_FILE" ] && _fatal $E_MISSING_FILE "Missing or not a file: $SCRIPT_FILE"

	case "$TYPE" in
		initial | major | minor | patch) ;;
		*) _fatal $E_ARGS "Invalid release type: $TYPE. Must be one of: initial, major, minor, patch." ;;
	esac

	case "$TYPE" in
		initial)
			_initial_release
			;;
		major | minor | patch)
			version-commit "$SCRIPT_DIR" "$TYPE"
			;;
	esac

	if [ "$PUBLISH_GITHUB" -eq 1 ]; then
		_push_release
		version-release "$SCRIPT_DIR"
	fi
}

_initial_release() {
	_require git version

	local version
	local repo_root
	local tag

	version="$(version show "$SCRIPT_FILE")"
	tag="$SCRIPT_NAME@$version"

	if git rev-parse -q --verify "refs/tags/$tag" > /dev/null; then
		_fatal $E_EXISTING_TAG "Tag already exists: $tag"
	fi

	repo_root="$(git -C "$SCRIPT_DIR" rev-parse --show-toplevel)"
	cd "$repo_root" || _fatal $E_MISSING_FILE "Cannot change directory to git repo root: $repo_root"

	git add "$SCRIPT_DIR"
	git commit -m "Add $SCRIPT_NAME" -- "$SCRIPT_DIR"
	git tag -a "$tag" -m "$SCRIPT_NAME v$version"
}

_push_release() {
	_require git

	local repo_root

	repo_root="$(git -C "$SCRIPT_DIR" rev-parse --show-toplevel)"
	cd "$repo_root" || _fatal $E_MISSING_FILE "Cannot change directory to git repo root: $repo_root"

	git push --follow-tags
}

_fatal() {
	local exit_code=$1
	shift
	echo "FATAL: $*" >&2
	exit "$exit_code"
}

_require() {
	missing_bin=0

	for bin in "$@"; do
		if ! which "$bin" > /dev/null 2>&1; then
			missing_bin=1
			echo "Required: $bin" >&2
		fi
	done

	if [ $missing_bin -ne 0 ]; then
		_fatal "$E_MISSING_APP" "One or more executables or apps are missing."
	fi
}

release_main "$@"
