#!/usr/bin/env bash
# Update or show version of a script.

version_main() {
	# export PS4='+ ${BASH_SOURCE}:${LINENO}:${FUNCNAME[0]}() '
	# set -x
	set -euo pipefail

	E_ARGS=16
	E_NO_FILE=17
	E_NO_VERSION=18

	[ $# -eq 0 ] && _usage && return
	[ $# -lt 2 ] && _usage && return $E_ARGS

	CMD="$1"
	FILE="$2"

	[ ! -f "$FILE" ] && echo "Missing file: $FILE" >&2 && return $E_NO_FILE

	PACKAGE_JSON="$(_package_json_for "$FILE")"
	VERSION_SOURCE="shell"

	if [ -f "$PACKAGE_JSON" ]; then
		VERSION="$(_read_package_version "$PACKAGE_JSON")"
		VERSION_SOURCE="package"
	else
		VERSION="$(_read_shell_version "$FILE")"
	fi

	[ -z "$VERSION" ] && echo "No VERSION found." >&2 && return $E_NO_VERSION

	case "$CMD" in
	show)
		echo "$VERSION"
		;;
	major | minor | patch)
		_update "$VERSION_SOURCE" "$FILE" "$PACKAGE_JSON"
		;;
	*)
		echo "Invalid command: $CMD" >&2 && return $E_ARGS
		;;
	esac
}

_package_json_for() {
	local file=$1
	local dir

	dir="$(dirname "$file")"
	echo "$dir/package.json"
}

_read_package_version() {
	local package_json=$1

	node -e '
const fs = require("node:fs");
const file = process.argv[1];
const pkg = JSON.parse(fs.readFileSync(file, "utf8"));
if (typeof pkg.version !== "string") {
  process.exit(1);
}
process.stdout.write(pkg.version);
' "$package_json"
}

_read_shell_version() {
	local file=$1

	grep -m1 -E "^VERSION=['\"]?(\d+\.){2}(\d+)" "$file" | grep -o -E '(\d+\.){2}(\d+)' || true
}

_update() {
	local source=$1
	local file=$2
	local package_json=$3
	local major
	local minor
	local patch

	IFS=. read -r major minor patch <<<"$VERSION"

	case "$CMD" in
	major)
		major="$((major + 1))"
		minor=0
		patch=0
		;;
	minor)
		minor="$((minor + 1))"
		patch=0
		;;
	patch)
		patch="$((patch + 1))"
		;;
	esac

	NEW_VERSION="$major.$minor.$patch"

	printf "%s %s %s\n" "$VERSION" "$NEW_VERSION" "$file"

	case "$source" in
	package)
		_write_package_version "$package_json" "$NEW_VERSION"
		;;
	shell)
		_write_shell_version "$file" "$NEW_VERSION"
		;;
	esac
}

_write_package_version() {
	local package_json=$1
	local new_version=$2

	node -e '
const fs = require("node:fs");
const file = process.argv[1];
const version = process.argv[2];
const pkg = JSON.parse(fs.readFileSync(file, "utf8"));
pkg.version = version;
fs.writeFileSync(file, JSON.stringify(pkg, null, 2) + "\n");
' "$package_json" "$new_version"
}

_write_shell_version() {
	local file=$1
	local new_version=$2

	export NEW_VERSION="$new_version"
	perl -pi -e "s/^(VERSION=['\"]?)(\d+\.){2}(\d+)/\$1\$ENV{NEW_VERSION}/" "$file"
}

_usage() {
	echo "USAGE: $(basename "$0") [<major|minor|patch|show>] <scriptfile>"
}

version_main "$@"
