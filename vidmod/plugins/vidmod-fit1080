#!/usr/bin/env bash
# vidmod fit1080
# Fit a video into a centered 1920x1080 black frame.

VERSION='1.0.0'

[ -n "${VIDMOD_LIB:-}" ] || VIDMOD_LIB="$(dirname "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)")/lib/vidmod.sh"

# shellcheck source=../lib/vidmod.sh
. "$VIDMOD_LIB"

fit1080_start() {
	local ffmpeg_extra_opts=
	local input=
	local output=
	local opt

	OPTIND=1
	while getopts :f:ho: opt; do
		case $opt in
			f) ffmpeg_extra_opts="$OPTARG" ;;
			h)
				fit1080_help
				return
				;;
			o) output="$OPTARG" ;;
			:) fit1080_invalid_opt "$OPTARG" ;;
			*) fit1080_invalid_opt "$OPTARG" ;;
		esac
	done

	shift "$((OPTIND - 1))"

	[ $# -lt 1 ] && fit1080_help && return $E_ARGS
	[ $# -gt 1 ] && fit1080_help && return $E_ARGS

	input="$1"

	[ -f "$input" ] || _fatal "$E_NO_FILE" "File not found: $input"

	if [ -z "$output" ]; then
		output="$(fit1080_output_path "$input")"
	fi

	_echo "<= $input"
	_echo "=> $output"

	vidmod_ffmpeg "$input" "$output" "$ffmpeg_extra_opts" \
		-vf "scale=1920:1080:force_original_aspect_ratio=decrease,pad=1920:1080:(ow-iw)/2:(oh-ih)/2" \
		-c:a copy
}

fit1080_help() {
	cat << USAGE
$USAGE_NAME $VERSION

USAGE: $USAGE_NAME [<options>] [-o <output>] <input>

Fit a video into a centered 1920x1080 black frame.

OPTIONS:

	-f        Extra ffmpeg options.
	-h        Show this help screen.
	-o        Output video file.
	-v        Show plugin name and version number.

USAGE
}

fit1080_output_path() {
	local input=$1
	local output_dir
	local input_name
	local input_stem
	local input_ext

	output_dir="$(dirname "$input")"
	input_name="$(basename "$input")"
	input_stem="${input_name%.*}"
	input_ext="$(echo "$input_name" | grep -o '\.[^.]*$')"

	if [ "$input_stem" = "$input_name" ] || [ -z "$input_stem" ]; then
		input_stem="$input_name"
	fi

	_echo "$output_dir/$input_stem-fit1080$input_ext"
}

fit1080_invalid_opt() {
	local invalid_opt=$1

	_error "Invalid option: -$invalid_opt"
	_echo
	fit1080_help
	exit $E_ARGS
}

vidmod_plugin_run "$@"
